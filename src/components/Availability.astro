---
---

<section id="availability" class="availability">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Availability</p>
      <h2>Real-time calendar</h2>
      <p class="section-intro">
        Live availability and nightly pricing — synced every 30 minutes.
        Greyed-out dates are already booked.
      </p>
    </div>

    <div class="calendar-wrap">
      <div id="availability-calendar" class="calendar" aria-live="polite">
        <div class="calendar-loading">Loading availability...</div>
      </div>

      <div id="range-summary" class="range-summary" hidden>
        <div class="range-summary-grid">
          <div class="range-dates">
            <span class="label">Your stay</span>
            <span class="value" data-range-dates></span>
          </div>
          <div class="range-nights">
            <span class="label">Nights</span>
            <span class="value" data-range-nights></span>
          </div>
          <div class="range-avg">
            <span class="label">Avg. / night</span>
            <span class="value" data-range-avg></span>
          </div>
          <div class="range-total">
            <span class="label">Subtotal</span>
            <span class="value" data-range-total></span>
          </div>
        </div>
        <p class="range-disclaimer">
          A 2.9% card processing fee is added at checkout.
        </p>
        <div class="range-actions">
          <button type="button" class="button" data-range-book>
            Book &amp; Pay Now
          </button>
          <button type="button" class="button button-secondary" data-range-cta>
            Inquire instead
          </button>
        </div>
        <p class="range-cancel-policy">
          <strong>Cancellation:</strong> full refund &gt; 30 days before
          check-in · 50% 7–29 days · non-refundable within 7 days.
        </p>
      </div>

      <p class="calendar-note" data-calendar-note>
        Tap a check-in date, then a check-out date to see your total.
      </p>
    </div>
  </div>
</section>

<script is:inline>
  (async function () {
    const target = document.getElementById('availability-calendar');
    if (!target) return;

    async function loadAvailability() {
      try {
        const res = await fetch('/.netlify/functions/availability');
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json();
        return {
          booked: data.booked || [],
          checkinDays: data.checkinDays || [],
        };
      } catch (err) {
        console.error('availability fetch failed', err);
        return null;
      }
    }

    async function loadPricing() {
      try {
        const res = await fetch('/.netlify/functions/pricing');
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json();
        return data.prices || {};
      } catch (err) {
        console.warn('pricing fetch failed (calendar will render without prices)', err);
        return {};
      }
    }

    function toISODate(d) {
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      return `${y}-${m}-${day}`;
    }

    const summary = document.getElementById('range-summary');
    const summaryDates = summary && summary.querySelector('[data-range-dates]');
    const summaryNights = summary && summary.querySelector('[data-range-nights]');
    const summaryAvg = summary && summary.querySelector('[data-range-avg]');
    const summaryTotal = summary && summary.querySelector('[data-range-total]');
    const summaryCta = summary && summary.querySelector('[data-range-cta]');
    const summaryBook = summary && summary.querySelector('[data-range-book]');
    const calendarNote = document.querySelector('[data-calendar-note]');

    function fmtMoney(n) {
      return '$' + Math.round(n).toLocaleString('en-US');
    }

    function fmtRange(start, end) {
      const opts = { month: 'short', day: 'numeric' };
      const sameYear = start.getFullYear() === end.getFullYear();
      const startStr = start.toLocaleDateString('en-US', opts);
      const endStr = end.toLocaleDateString('en-US', sameYear ? opts : { ...opts, year: 'numeric' });
      const yearSuffix = sameYear ? `, ${end.getFullYear()}` : '';
      return `${startStr} → ${endStr}${yearSuffix}`;
    }

    function showSummary(start, end, prices) {
      if (!summary) return;
      const nights = Math.round((end - start) / (1000 * 60 * 60 * 24));
      let total = 0;
      let pricedNights = 0;
      const cur = new Date(start);
      while (cur < end) {
        const iso = toISODate(cur);
        const p = prices[iso];
        if (typeof p === 'number') {
          total += p;
          pricedNights += 1;
        }
        cur.setDate(cur.getDate() + 1);
      }
      const avg = pricedNights ? total / pricedNights : 0;

      summaryDates.textContent = fmtRange(start, end);
      summaryNights.textContent = String(nights);
      summaryAvg.textContent = avg ? fmtMoney(avg) : '—';
      summaryTotal.textContent = total ? fmtMoney(total) : 'Quote on request';

      summary.hidden = false;
      if (calendarNote) calendarNote.hidden = true;
    }

    function hideSummary() {
      if (!summary) return;
      summary.hidden = true;
      if (calendarNote) calendarNote.hidden = false;
    }

    function ctaHandler(start, end) {
      return function () {
        const checkin = document.getElementById('checkin');
        const checkout = document.getElementById('checkout');
        if (checkin && checkin._flatpickr) checkin._flatpickr.setDate(start, true);
        if (checkout && checkout._flatpickr) checkout._flatpickr.setDate(end, true);
        const inquireSection = document.getElementById('inquire');
        if (inquireSection) inquireSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      };
    }

    function bookHandler(start, end) {
      return async function () {
        if (!summaryBook) return;
        const guestsEl = document.getElementById('guests');
        const guests = (guestsEl && guestsEl.value) || '2';

        const originalText = summaryBook.textContent;
        summaryBook.disabled = true;
        summaryBook.textContent = 'Connecting to checkout…';

        try {
          const res = await fetch('/.netlify/functions/create-checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              checkin: toISODate(start),
              checkout: toISODate(end),
              guests,
            }),
          });
          const data = await res.json();
          if (!res.ok || !data.url) {
            throw new Error(data.error || 'Checkout unavailable');
          }
          window.location.href = data.url;
        } catch (err) {
          console.error('Checkout failed', err);
          summaryBook.disabled = false;
          summaryBook.textContent = originalText;
          alert(
            'Sorry — we couldn\'t connect to checkout right now. ' +
            'Please use the Inquire option below and we\'ll send you ' +
            'a payment link directly.\n\n' +
            'Error: ' + err.message,
          );
        }
      };
    }

    function initCalendar(booked, checkinDays, prices) {
      if (typeof flatpickr === 'undefined') {
        setTimeout(() => initCalendar(booked, checkinDays, prices), 200);
        return;
      }

      // Same-day turnover support:
      // - "fullyBlocked" = middle nights of every existing reservation. These
      //   are nights someone else is sleeping, so the calendar must hard-block
      //   them: they can't be a new booking's check-in, check-out, or middle
      //   night.
      // - "checkinDays" = the date each existing reservation begins. Someone
      //   sleeps that night, so a new booking can't start or span there, but
      //   a new booking CAN check OUT on that day (the cleaner has the gap
      //   between 11am check-out and 4pm check-in to flip the unit).
      // We only mark fullyBlocked as flatpickr-disabled. checkinDays render
      // as a "checkout-only" tile and are validated in onChange — if the user
      // ends up using one as their START, we reject the range there.
      const checkinSet = new Set(checkinDays || []);
      const fullyBlocked = (booked || []).filter((d) => !checkinSet.has(d));
      const fullyBlockedSet = new Set(fullyBlocked);

      target.innerHTML = '';
      flatpickr(target, {
        inline: true,
        mode: 'range',
        minDate: 'today',
        showMonths: window.innerWidth >= 900 ? 2 : 1,
        disable: fullyBlocked,
        allowInput: false,
        onReady: function (_, __, instance) {
          instance.calendarContainer.classList.add('availability-flatpickr');
          if (prices && Object.keys(prices).length) {
            instance.calendarContainer.classList.add('with-prices');
          }
        },
        onChange: function (selectedDates, _, instance) {
          if (selectedDates.length === 2) {
            const [start, end] = selectedDates;
            const startIso = toISODate(start);
            const endIso = toISODate(end);

            // Reject 0-night ranges (clicked the same date twice).
            if (startIso === endIso) {
              hideSummary();
              return;
            }

            // Reject ranges that try to START on a turnover day —
            // someone is already sleeping there.
            if (checkinSet.has(startIso)) {
              instance.clear();
              hideSummary();
              alert(
                'That check-in date isn\'t available — another guest checks in that day. ' +
                'Try the day after their checkout instead.',
              );
              return;
            }

            // Defensive: re-verify no occupied night sneaks into the range.
            // flatpickr already enforces this via `disable`, but turnover
            // days are intentionally not in `disable`, so we double-check.
            const cur = new Date(start);
            while (cur < end) {
              const iso = toISODate(cur);
              if (fullyBlockedSet.has(iso) || checkinSet.has(iso)) {
                // Allow checkinSet on the very last iteration (the
                // checkout day) — it's the turnover case we want to
                // permit. Otherwise it's a true conflict.
                const next = new Date(cur);
                next.setDate(next.getDate() + 1);
                const isCheckoutTurnover =
                  next.getTime() === end.getTime() && checkinSet.has(iso) && !fullyBlockedSet.has(iso);
                if (!isCheckoutTurnover) {
                  instance.clear();
                  hideSummary();
                  alert(
                    'Those dates aren\'t fully available — there\'s a booking conflict. ' +
                    'Please pick a different range.',
                  );
                  return;
                }
              }
              cur.setDate(cur.getDate() + 1);
            }

            showSummary(start, end, prices);
            if (summaryCta) summaryCta.onclick = ctaHandler(start, end);
            if (summaryBook) summaryBook.onclick = bookHandler(start, end);
          } else {
            hideSummary();
          }
        },
        onDayCreate: function (_, __, ___, dayElem) {
          if (!dayElem.dateObj) return;
          if (dayElem.classList.contains('prevMonthDay')) return;
          if (dayElem.classList.contains('nextMonthDay')) return;

          const iso = toISODate(dayElem.dateObj);

          // Mark turnover days for styling — they're not flatpickr-disabled
          // (so they can be picked as a new booking's checkout) but they
          // also can't start a new stay.
          if (checkinSet.has(iso) && !fullyBlockedSet.has(iso)) {
            dayElem.classList.add('turnover-day');
            dayElem.title = 'Checkout-only — another guest checks in this day';
          }

          if (dayElem.classList.contains('flatpickr-disabled')) return;

          const price = prices[iso];
          if (!price) return;

          const label = document.createElement('span');
          label.className = 'price-label';
          label.textContent = '$' + price;
          dayElem.appendChild(label);
        },
      });
    }

    const [availability, prices] = await Promise.all([loadAvailability(), loadPricing()]);
    if (availability === null) {
      target.innerHTML =
        '<div class="calendar-error">We couldn\'t load the live calendar. Please submit an inquiry below and we\'ll confirm availability by email.</div>';
      return;
    }
    const { booked, checkinDays } = availability;
    initCalendar(booked, checkinDays, prices);

    window.__bookedDates = booked;
    window.dispatchEvent(new CustomEvent('availability-loaded', { detail: { booked } }));
  })();
</script>

<style is:global>
  .availability {
    background: var(--color-surface);
  }

  .availability .section-header {
    margin-bottom: var(--space-md);
  }

  .calendar-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .calendar {
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .calendar:empty {
    min-height: 0;
  }

  .calendar-loading,
  .calendar-error {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    text-align: center;
    padding: var(--space-md);
    max-width: 480px;
  }

  .calendar-note {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    text-align: center;
  }

  .availability-flatpickr.flatpickr-calendar {
    font-family: var(--font-sans);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .availability-flatpickr .flatpickr-day.flatpickr-disabled {
    background: #f0ebe3;
    color: #b8afa4;
    text-decoration: line-through;
  }

  .availability-flatpickr .flatpickr-day.today {
    border-color: var(--color-accent);
  }

  .availability-flatpickr.with-prices .dayContainer,
  .availability-flatpickr.with-prices .flatpickr-weekdaycontainer,
  .availability-flatpickr.with-prices .flatpickr-weekdays {
    width: 364px;
    min-width: 364px;
    max-width: 364px;
  }

  .availability-flatpickr.with-prices .flatpickr-day,
  .availability-flatpickr.with-prices .flatpickr-weekday {
    flex-basis: 14.2857%;
    max-width: 52px;
  }

  .availability-flatpickr.with-prices .flatpickr-day {
    height: 52px;
    max-height: 52px;
    line-height: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .availability-flatpickr.with-prices .dayContainer,
    .availability-flatpickr.with-prices .flatpickr-weekdaycontainer,
    .availability-flatpickr.with-prices .flatpickr-weekdays {
      width: 322px;
      min-width: 322px;
      max-width: 322px;
    }
    .availability-flatpickr.with-prices .flatpickr-day,
    .availability-flatpickr.with-prices .flatpickr-weekday {
      max-width: 46px;
    }
    .availability-flatpickr.with-prices .flatpickr-day {
      height: 48px;
      max-height: 48px;
    }
    .availability-flatpickr.with-prices .flatpickr-day .price-label {
      font-size: 0.68rem;
    }
  }

  .availability-flatpickr.with-prices .flatpickr-day .price-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .availability-flatpickr.with-prices .flatpickr-day.flatpickr-disabled .price-label {
    display: none;
  }

  /*
   * Turnover days: another guest is checking in this day, so a new booking
   * can only END here (checkout). Visually we tint the lower-left half to
   * communicate "first half of the day is taken." The tile stays clickable.
   */
  .availability-flatpickr .flatpickr-day.turnover-day {
    background: linear-gradient(
      to top right,
      #f0ebe3 0%,
      #f0ebe3 49%,
      transparent 51%,
      transparent 100%
    );
  }

  .availability-flatpickr .flatpickr-day.turnover-day.endRange,
  .availability-flatpickr .flatpickr-day.turnover-day.selected {
    background: var(--color-accent);
    color: white;
  }

  .availability-flatpickr .flatpickr-day.selected,
  .availability-flatpickr .flatpickr-day.startRange,
  .availability-flatpickr .flatpickr-day.endRange,
  .availability-flatpickr .flatpickr-day.selected.startRange,
  .availability-flatpickr .flatpickr-day.selected.endRange {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .availability-flatpickr .flatpickr-day.selected .price-label,
  .availability-flatpickr .flatpickr-day.startRange .price-label,
  .availability-flatpickr .flatpickr-day.endRange .price-label,
  .availability-flatpickr .flatpickr-day.inRange .price-label {
    color: rgba(255, 255, 255, 0.9);
  }

  .availability-flatpickr .flatpickr-day.inRange {
    background: rgba(181, 101, 68, 0.18);
    border-color: rgba(181, 101, 68, 0.18);
    color: var(--color-text);
    box-shadow: none;
  }

  .availability-flatpickr .flatpickr-day.inRange .price-label {
    color: var(--color-text-muted);
  }

  .range-summary {
    width: 100%;
    max-width: 560px;
    margin-top: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .range-summary[hidden] {
    display: none;
  }

  .range-summary-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.2fr;
    gap: var(--space-sm);
    align-items: end;
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 600px) {
    .range-summary-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .range-summary .label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.3rem;
    font-weight: 500;
  }

  .range-summary .value {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.2;
    font-variant-numeric: tabular-nums;
  }

  .range-summary .range-total .value {
    font-size: 1.4rem;
    color: var(--color-accent);
  }

  .range-disclaimer {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .range-actions {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-sm);
  }

  @media (max-width: 520px) {
    .range-actions {
      grid-template-columns: 1fr;
    }
  }

  .range-actions .button {
    width: 100%;
  }

  .range-cancel-policy {
    margin-top: var(--space-sm);
    margin-bottom: 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .range-cancel-policy strong {
    color: var(--color-text);
  }
</style>
