---
const placeholders = [
  { label: 'Exterior', aspect: '4/3' },
  { label: 'Living room', aspect: '4/3' },
  { label: 'King bedroom', aspect: '1/1' },
  { label: 'Kitchen', aspect: '1/1' },
  { label: 'Queen bedroom', aspect: '4/3' },
  { label: 'Patio', aspect: '4/3' },
];
---

<section id="gallery" class="gallery">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Gallery</p>
      <h2>A look inside</h2>
    </div>
    <div class="gallery-grid">
      {placeholders.map((p, i) => (
        <div class={`photo photo-${i}`} style={`aspect-ratio: ${p.aspect}`}>
          <span>{p.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    background: var(--color-bg);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  .photo {
    background: linear-gradient(135deg, #e8d9c4 0%, #c9a876 100%);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.4);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    overflow: hidden;
  }

  .photo-0 {
    background: linear-gradient(135deg, #d4b896 0%, #b08968 100%);
  }

  .photo-1 {
    background: linear-gradient(135deg, #e8d9c4 0%, #d4b896 100%);
  }

  .photo-2 {
    background: linear-gradient(135deg, #c9a876 0%, #b08968 100%);
  }

  .photo-3 {
    background: linear-gradient(135deg, #d4b896 0%, #b08968 100%);
  }

  .photo-4 {
    background: linear-gradient(135deg, #b08968 0%, #8b6f4e 100%);
  }

  .photo-5 {
    background: linear-gradient(135deg, #e8d9c4 0%, #b08968 100%);
  }
</style>
