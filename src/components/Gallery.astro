---
const photos = [
  { src: '/images/exterior.avif', alt: 'Casa Blanca exterior', aspect: '4/3' },
  { src: '/images/livingroom.avif', alt: 'Living room', aspect: '4/3' },
  { src: '/images/kingbedroom.avif', alt: 'King bedroom', aspect: '1/1' },
  { src: '/images/kitchen.avif', alt: 'Kitchen', aspect: '1/1' },
  { src: '/images/queenbedroom.avif', alt: 'Queen bedroom', aspect: '4/3' },
  { src: '/images/patio.avif', alt: 'Back patio', aspect: '4/3' },
];
---

<section id="gallery" class="gallery">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Gallery</p>
      <h2>A look inside</h2>
    </div>
    <div class="gallery-grid">
      {photos.map((p) => (
        <img
          src={p.src}
          alt={p.alt}
          class="photo"
          style={`aspect-ratio: ${p.aspect}`}
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    background: var(--color-bg);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
    transition: transform 0.4s ease;
  }

  .photo:hover {
    transform: scale(1.02);
  }
</style>
